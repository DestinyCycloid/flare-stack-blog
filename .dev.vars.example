# ===========================================
# 服务端环境变量（Wrangler 注入 Worker env）
# ===========================================

# --- 环境标识 ---
ENVIRONMENT=dev

# --- 存储配置 ---
# 图片存储类型: r2 或 github
# github: 使用 GitHub + jsDelivr CDN（完全免费，不需要绑卡）推荐
# r2: 使用 Cloudflare R2 存储（需要绑卡，但有 10GB 免费额度）
STORAGE_TYPE=github

# GitHub 图床配置（推荐，完全免费）
GITHUB_IMAGE_TOKEN=your-github-personal-access-token
GITHUB_IMAGE_REPO=username/repo-name
# GITHUB_IMAGE_BRANCH=main
# GITHUB_IMAGE_PATH=images/

# R2 配置（可选，需要在 wrangler.jsonc 中配置 r2_buckets）
# STORAGE_TYPE=r2

# --- 认证配置（Better Auth） ---
BETTER_AUTH_SECRET=your-secret-key-run-openssl-rand-hex-32
BETTER_AUTH_URL=http://localhost:3000
ADMIN_EMAIL=your-email@example.com

# --- GitHub OAuth ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- CDN 缓存清理（可选） ---
# 如果不配置，项目会跳过 CDN 缓存清理功能
# 影响：发布/更新文章后，用户可能看到旧内容，需要等待缓存过期

# CLOUDFLARE_ZONE_ID=your-zone-id
# CLOUDFLARE_PURGE_API_TOKEN=your-purge-api-token
# DOMAIN=blog.example.com
# 可选：若使用独立 CDN 域名，设置后 purge 时优先使用此域名
# CDN_DOMAIN=cdn.example.com

# --- Umami 统计（可选） ---
# Umami Cloud: 设置 UMAMI_SRC=https://cloud.umami.is 并提供 UMAMI_API_KEY
# 自部署: 设置 UMAMI_SRC 为你的实例 URL 并提供 USERNAME/PASSWORD

VITE_UMAMI_WEBSITE_ID=your-umami-website-id

# Umami Cloud 配置:
UMAMI_SRC=https://cloud.umami.is
UMAMI_API_KEY=your-cloud-api-key

# 自部署 Umami 配置（如果使用自部署，请取消注释并注释掉上面的 Cloud 配置）:
# UMAMI_SRC=https://umami.example.com
# UMAMI_USERNAME=your-username
# UMAMI_PASSWORD=your-password

# --- Turnstile 人机验证 ---
# 测试key见：https://developers.cloudflare.com/turnstile/troubleshooting/testing/
# TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# --- GitHub API（可选，用于版本更新检查） ---
# 未认证请求限流 60 次/小时/IP，Cloudflare Workers 共享 IP 容易触发限流
# 创建无权限的 Fine-grained token: https://github.com/settings/personal-access-tokens
# GITHUB_TOKEN=your-github-token